APP_ENV=dev
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

API_KEY=replace-with-strong-admin-key
SHARE_TOKEN_SECRET=replace-with-long-random-secret
SHARE_TOKEN_TTL_MINUTES=1440
ACCESS_TOKEN_SECRET=replace-with-long-random-access-secret
REFRESH_TOKEN_SECRET=replace-with-long-random-refresh-secret
OAUTH_TOKEN_ENC_KEY=replace-with-long-random-encryption-secret
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_MINUTES=10080
RATE_LIMIT_PER_MINUTE=60

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/github/callback
GITHUB_API_BASE=https://api.github.com

DATABASE_URL=postgresql+asyncpg://analyzer:analyzer@postgres:5432/analyzer
REDIS_URL=redis://redis:6379/0
USE_REDIS_QUEUE=true
RUN_WORKER_IN_API=false

WORKER_MAX_ATTEMPTS=3
WORKER_BASE_BACKOFF_SECONDS=0.5

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
